# Copiá este archivo como `.env` y completá los valores.
# El .env NUNCA se sube a git (está en .gitignore).

# URL del RPC de Sepolia. Sacá una gratis en Alchemy (alchemy.com) o Infura.
# Ejemplo Alchemy: https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY
SEPOLIA_RPC_URL=

# API key de Etherscan (etherscan.io/myapikey). Con Etherscan API V2 esta misma
# key verifica en Sepolia (se enruta por chainid 11155111).
ETHERSCAN_API_KEY=

# (Opcional) Denominación fija del pool al desplegar, en wei. Default del script:
# 0.01 ETH (10000000000000000). El pool acepta depósitos de ESTE monto exacto.
# POOL_DENOMINATION=10000000000000000

# Clave privada de la wallet que despliega.
# ⚠️ USÁ UNA WALLET DE PRUEBA, descartable, SIN fondos reales. Solo ETH de faucet.
# ⚠️ NUNCA pongas acá la clave de una wallet con plata de verdad.
PRIVATE_KEY=
